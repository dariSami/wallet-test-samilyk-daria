# Shared settings — copy to .env
# Environment overrides — copy to .env.dev / .env.prod
# Switch env: TEST_ENV=prod npm test (default: dev)

# ── .env (shared) ───────────────────────────────────
SLOW_MO=50

# Add wallets: WALLET_{NAME}_SEED + WALLET_{NAME}_PASSWORD
WALLET_MAIN_SEED=your twelve word seed phrase here
WALLET_MAIN_PASSWORD=YourTestPassword123!

# ── .env.dev / .env.prod (only what differs) ────────
BASE_URL=https://dev.tradegenius.com
